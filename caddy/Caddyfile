# 复用的静态站点通用配置片段
(static_common) {
	encode gzip zstd
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# 全站基础 CSP (landingpage.html 及 index.html 都有大量 inline style/script, 保留 unsafe-inline)
		# 若后续去除内联脚本，可去掉 'unsafe-inline'
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' https://fonts.loli.net https://gstatic.loli.net; connect-src 'self' https://api.kl8s.com https://skhsn6q4pnv95.ezdemo.xyz https://gy1v06omopzc8.ezdemo.xyz https://user.polarisnet.cloud; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-site"
		X-Permitted-Cross-Domain-Policies "none"
		Origin-Agent-Cluster "?1"
	}
	# 确保JavaScript文件有正确的MIME类型
	@js {
		path_regexp jsExt \.(m?js)$
	}
	header @js Content-Type "application/javascript; charset=utf-8"
	
	# 确保CSS文件有正确的MIME类型  
	@css {
		path_regexp cssExt \.css$
	}
	header @css Content-Type "text/css; charset=utf-8"
	@immutable {
		path_regexp staticExt \.(?:js|mjs|css|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|map)$
	}
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# 避免 HTML 长期缓存
	@html path_regexp htmlExt \.html$
	header @html Cache-Control "no-cache, max-age=0, must-revalidate"

	# 独立配置文件不走 immutable；如文件名不同可再加路径
	@configFile path /config.js
	header @configFile Cache-Control "no-cache, max-age=0, must-revalidate"
	log {
		output file ./caddy-access.log {
			roll_size 50mb
			roll_keep 7
			roll_keep_for 168h
		}
		format json
	}
}

# 主站 + tui 共用相同前端构建目录 (请按需修改为你的真实路径)
polarisnet.cloud, polarislnk.com, t.polarisnet.cloud, t.polarislnk.com {
	import static_common
	# Windows 下推荐使用正斜杠，Caddy 可识别；修改为你的构建输出目录
	root * /var/www/polarisnet.cloud

	# 仅允许 landingpage.html 被同源 iframe 加载，其它页面保持 DENY
	@landingPage path /landingpage.html
	header @landingPage {
		-X-Frame-Options
		X-Frame-Options "SAMEORIGIN"
	}
	try_files {path} {path}/ /index.html
	file_server
}

# 单页面静态站 (只有一个 index.html)
polarisnet.link {
	import static_common
	root * /var/www/polarisnet.link
	# 访问任何路径都返回 index.html (单页或单文件)
	try_files {path} {path}/ /index.html
	file_server
	# 如果你真的只想暴露 index.html 且禁止其它文件，可改为：
	# handle {
	#     rewrite * /index.html
	#     file_server {
	#         root /var/www/polarisnet.link
	#     }
	# }
}

# 反向代理本地应用 (用户中心) -> 127.0.0.1:3000
user.polarisnet.cloud, user.polarislnk.com {
	reverse_proxy 127.0.0.1:3000 {
		transport http {
			read_timeout 30s
			dial_timeout 5s
		}
		# 可选：健康检查
		# health_uri /healthz
	}
	log {
		output file ./caddy-user.log {
			roll_size 20mb
			roll_keep 5
		}
		format console
	}
}

# 代理到外部 API
s.polarislnk.com,s.polarisub.click {
	reverse_proxy https://api.polarislnk.com {
		header_up Host api.polarislnk.com
	}
}

s.polarisnet.cloud,s.polarisub.click {
	reverse_proxy https://api.polarislnk.com {
		header_up Host api.polarislnk.com
	}
}

